# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# Paths
DATA_DIR=./data
CACHE_DIR=./data/cache
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
EVIDENCE_DB=./data/cache/evidence.sqlite

# Networking
HTTP_TIMEOUT=15
HTTP_MAX_RETRIES=3

# Defaults
DEFAULT_TIMEFRAME=6mo
NEWS_MAX_ITEMS=15
ARTICLE_MAX_ITEMS=5

# India defaults
DEFAULT_EXCHANGE=NSE
DEFAULT_CURRENCY=INR
LOCALE_REGION=IN
MFAPI_BASE_URL=https://api.mfapi.in

# News sources (optional override)
# Format: "Display Name|domain,Display Name|domain"
# Leave blank to use the default 10-outlet Indian list
INDIA_NEWS_SOURCES=
NEWS_PER_SOURCE_MAX=3

# Feature toggles
ENABLE_CHART_OCR=true
ENABLE_YOUTUBE=true
